# GOOGLE_GENAI_USE_VERTEXAI=true
# GOOGLE_CLOUD_PROJECT=
# GOOGLE_CLOUD_LOCATION=us-central1
# GOOGLE_APPLICATION_CREDENTIALS_HOST_PATH=./secrets/gcp-sa.json

# HUME
HUME_API_KEY=
HUME_CONFIG_ID=

# SPEECHMATICS
SPEECHMATICS_API_KEY=

# SARVAM
SARVAM_API_KEY=

