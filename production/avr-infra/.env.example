# General
PORT=3001
MY_DOMAIN=agentvoiceresponse.com

# Admin Credentials
ADMIN_USERNAME=admin
ADMIN_PASSWORD=

# Asterisk
ARI_URL=http://avr-asterisk:8088/ari
ARI_USERNAME=avr
ARI_PASSWORD=

# Database
DATABASE_HOST=127.0.0.1
DATABASE_PORT=3309
DATABASE_NAME=avr-app
DATABASE_USERNAME=avr
DATABASE_PASSWORD=

DATABASE_ROOT_PASSWORD=

# Container Ports
CORE_PORT_START=5000
ASR_PORT_START=6000
LLM_PORT_START=7000
TTS_PORT_START=8000
AMI_PORT=9000

# Network
AVR_NETWORK=avr

# Deepgram
DEEPGRAM_API_KEY=
# Only for Deepgram STS
AGENT_PROMPT=

# OpenRouter
OPENROUTER_API_KEY=
OPENROUTER_MODEL=deepseek/deepseek-chat-v3-0324:free

# Kokoro
KOKORO_BASE_URL=http://host.docker.internal:8880

# Anthropic
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-3-haiku-20240307
ANTHROPIC_MAX_TOKENS=1024
ANTHROPIC_TEMPERATURE=1
ANTHROPIC_SYSTEM_PROMPT="You are a helpful assistant."

# AMI
AMI_HOST=avr-asterisk
AMI_PORT=5038
AMI_USERNAME=avr
AMI_PASSWORD=

# GEMINI
GEMINI_API_KEY=

# ELEVENLABS
ELEVENLABS_API_KEY=
ELEVENLABS_MODEL_ID=scribe_v1
ELEVENLABS_LANGUAGE_CODE=en
ELEVENLABS_VOICE_ID=Xb7hH8MSUJpSbSDYk0k2
ELEVENLABS_AGENT_ID=

# OPENAI
OPENAI_API_KEY=

# OpenAI LLM (docker-compose-openai.yml)
OPENAI_MODEL=gpt-3.5-turbo
OPENAI_MAX_TOKENS=100
OPENAI_TEMPERATURE=0.0

