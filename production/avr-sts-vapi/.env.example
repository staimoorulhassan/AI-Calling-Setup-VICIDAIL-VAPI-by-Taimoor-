PORT=6042

# VAPI credentials (https://dashboard.vapi.ai)
# NOTE: VAPI_PRIVATE_KEY must contain the PUBLIC key value for /call/web endpoint
VAPI_PRIVATE_KEY=
VAPI_PUBLIC_KEY=
VAPI_ASSISTANT_ID=

# ViciDial 3-way transfer (optional)
# Leave VICIDIAL_URL unset to disable
VICIDIAL_URL=
VICIDIAL_USER=
VICIDIAL_PASS=
VICIDIAL_AGENT_USER=
VICIDIAL_AGENT_PASS=

# avr-ami bridge URL
AMD_SENSITIVITY=conservative
AVR_AMI_URL=http://avr-ami:6006

# Delay (ms) between transfer success and dropping the AI's leg
TRANSFER_CONFIRM_DELAY_MS=8000
