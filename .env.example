# ============================================================================
# avr-infra .env.example — copy to /opt/avr/avr-infra/.env and fill in.
# DO NOT commit the resolved .env file. .gitignore enforces this.
# ============================================================================

# --- VAPI (docker-compose-vapi.yml) ----------------------------------------
# Get keys from https://dashboard.vapi.ai/org/api-keys (private)
# and https://dashboard.vapi.ai → your assistant → publish (assistant id)
VAPI_PRIVATE_KEY=
VAPI_PUBLIC_KEY=
VAPI_ASSISTANT_ID=

# --- ViciDial AMI bridge (used by avr-ami) ---------------------------------
AMI_HOST=
AMI_PORT=5038
AMI_USERNAME=
AMI_PASSWORD=

# --- Container network -----------------------------------------------------
AVR_NETWORK=avr

# --- Optional STS providers (only the one in active compose file matters) --
DEEPGRAM_API_KEY=
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
ELEVENLABS_API_KEY=
GEMINI_API_KEY=
