# /etc/ai_agent/config.yaml — copy to that path and fill in real values.
# Read by agi/precheck_amd.py, agi/disposition.py, and agi/transfer_webhook.py.

vicidial:
  # Non-agent API endpoint. On the same box this is usually:
  api_url: "http://127.0.0.1/vicidial/non_agent_api.php"
  api_user: "REPLACE_ME"        # ViciDial admin user with API access
  api_pass: "REPLACE_ME"
  source: "AIAgent"             # appears in CDR/audit trail

# avr-bridge is configured in /etc/asterisk/sip-vicidial.conf — these are
# here only for documentation / future use by orchestration scripts.
avr_bridge:
  host: "172.18.0.5"            # avr-asterisk container IP on the avr docker net
  port: 5060

vapi:
  # Used by avr-sts-vapi (NOT by the AGI scripts). Listed here so the whole
  # campaign config lives in one place. Real keys go in
  # /opt/avr/avr-infra/.env, never in this file.
  assistant_id: "REPLACE_ME"
  notes: "AI assistant configured via VAPI dashboard"

transfer:
  verifier_number: "REPLACE_ME"    # E.164 format e.g. +17543463674
  whisper_sound: "acs-transfer"    # sound file basename in /var/lib/asterisk/sounds/custom/
  conf_bridge_timeout: 30          # seconds to wait for verifier before CALLBK fallback
  webhook_port: 8088               # port for transfer_webhook.py Flask server
  webhook_secret: "REPLACE_ME"     # x-vapi-secret header value (match in VAPI dashboard)

ai:
  manager_url: ""               # optional: HTTP endpoint for campaign overrides
  default_timeout_sec: 600
