# /etc/ai_agent/config.yaml - copy to that path and fill in real values.
# Read by agi/precheck_amd.py, agi/disposition.py, and ai_campaign_runner.

vicidial:
  api_url: "https://127.0.0.1/vicidial/non_agent_api.php"
  api_user: "REPLACE_ME"        # ViciDial admin user with API access
  api_pass: "REPLACE_ME"
  source: "AIAgent"             # appears in CDR/audit trail
  verify_tls: false             # leave false for self-signed localhost cert

ami:
  host: "127.0.0.1"
  port: 5038
  username: "REPLACE_ME"        # see /etc/asterisk/manager.conf
  secret: "REPLACE_ME"

avr_bridge:
  host: "172.18.0.5"            # avr-asterisk container IP on the avr docker net
  port: 5060

vapi:
  assistant_id: "REPLACE_ME"
  notes: "AI assistant configured via VAPI dashboard"

outbound:
  caller_id_num: "REPLACE_ME"   # verified DID for outbound CID (no '+' prefix)
  caller_id_name: "AI Agent"

ai:
  manager_url: ""               # optional: HTTP endpoint for campaign overrides
  default_timeout_sec: 600
