PORT=6042

# VAPI credentials
VAPI_PRIVATE_KEY=your-vapi-private-key
VAPI_PUBLIC_KEY=your-vapi-public-key
VAPI_ASSISTANT_ID=your-vapi-assistant-id

# ViciDial integration
VICIDIAL_URL=http://192.168.1.100
# REQUIRED for dispositions: non-agent API user (vdc_agent_api_access=1,
# modify_leads in {1,2,3,4}, user_level>7, active). Without these, update_lead is
# rejected and every lead stays NEW.
VICIDIAL_USER=6666
VICIDIAL_PASS=your-api-user-password
# Used only for 3-way transfer (conf_newcall) — a real agent session.
VICIDIAL_AGENT_USER=agent1
VICIDIAL_AGENT_PASS=your-agent-password
# Fallback disposition for connected calls that end without a specific outcome.
VICIDIAL_DEFAULT_DISPO=DROP

# avr-ami bridge
AVR_AMI_URL=http://avr-ami:6006

# Transfer settings
TRANSFER_CONFIRM_DELAY_MS=8000

# AMD sensitivity: disabled | conservative | normal | aggressive
AMD_SENSITIVITY=conservative
